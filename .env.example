# LLM
# LLM_PROVIDER: auto (default, GITHUB_TOKEN diutamakan) | github | openai
LLM_PROVIDER=auto
GITHUB_TOKEN=
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Database
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=helpdesk
DATABASE_URL=postgresql://helpdesk:change-me@localhost:5432/helpdesk

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Telegram
TELEGRAM_BOT_TOKEN=
CSIRT_CHAT_ID=

# Logging
LOG_LEVEL=INFO

# Web Interface
WEB_SESSION_SECRET=change-me-in-production
WEB_CSRF_SECRET=change-me-in-production
WEB_COOKIE_SECURE=false
